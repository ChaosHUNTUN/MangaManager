<Window x:Class="MangaManager.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MangaManager" Height="700" Width="900"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing" Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_Drag">

    <Window.Resources>
        <!-- 颜色常量 -->
        <SolidColorBrush x:Key="BgPrimary" Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#14142A"/>
        <SolidColorBrush x:Key="BgCard" Color="#1A1A3A"/>
        <SolidColorBrush x:Key="BorderColor" Color="#1E1E3A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#A78BFA"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#F59E0B"/>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B5CF6"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#374151"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconBtn">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#252545"/>
            <Setter Property="Foreground" Value="#A78BFA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353565"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="QuickLinkBtn">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#1A2E1A"/>
            <Setter Property="Foreground" Value="#6EE7B7"/>
            <Setter Property="BorderBrush" Value="#4010B981"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4E2A"/>
                    <Setter Property="BorderBrush" Value="#8010B981"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- 主容器 -->
    <Border CornerRadius="12" Background="#0F0F1A" BorderBrush="#1E1E3A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========== 标题栏 ========== -->
            <Border Grid.Row="0" Background="#13132A" CornerRadius="12,12,0,0" Padding="16,10"
                    MouseLeftButtonDown="Window_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📚" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="MangaManager" FontSize="14" FontWeight="Bold"
                                   Foreground="#E0E0E0" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Background="#187C3AED" CornerRadius="8" Padding="6,2" Margin="10,0,0,0"
                                BorderBrush="#407C3AED" BorderThickness="1">
                            <TextBlock Text="v2.0" FontSize="10" Foreground="#A78BFA"/>
                        </Border>
                        <!-- 快捷入口 -->
                        <Border Background="#1A2E1A" CornerRadius="6" Padding="10,4" Margin="16,0,0,0" Cursor="Hand"
                                BorderBrush="#4010B981" BorderThickness="1"
                                MouseLeftButtonDown="OpenWeb_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="打开前端页面" FontSize="11" Foreground="#6EE7B7" Margin="6,0,0,0"
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" FontSize="14" Background="Transparent" Foreground="#888"
                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                Click="Minimize_Click" Style="{x:Null}"/>
                        <Button Content="✕" FontSize="12" Background="Transparent" Foreground="#888"
                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                Click="Close_Click" Style="{x:Null}"
                                MouseEnter="CloseBtn_MouseEnter" MouseLeave="CloseBtn_MouseLeave"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== 主体区域 ========== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,14,20,20">
                <StackPanel>
                    <!-- ========== 1. 服务管理 ========== -->
                    <Border Background="#14142A" CornerRadius="10" Padding="18,16" Margin="0,0,0,12"
                            BorderBrush="#1E1E3A" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙ 服务管理" FontSize="15" FontWeight="Bold" Foreground="#E0E0E0"/>
                                    <Border CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                                            Background="{Binding ElementName=TxtGlobalStatus, Path=Tag, FallbackValue=#1878350F}">
                                        <TextBlock x:Name="TxtGlobalStatus" Text="● 检查中..." FontSize="11"
                                                   Foreground="#F59E0B" VerticalAlignment="Center" Tag="#1878350F"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="▶ 全部启动" Style="{StaticResource PrimaryBtn}" FontSize="11"
                                            Padding="10,5" Click="BtnStartAll_Click" Background="#059669"/>
                                    <Button Content="⏹ 全部停止" FontSize="11" Background="#DC2626" Foreground="White"
                                            BorderThickness="0" Padding="10,5" Cursor="Hand" Margin="6,0,0,0"
                                            Click="BtnStopAll_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="10,5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <WrapPanel>
                                <!-- API 后端卡片 -->
                                <Border Background="#1A1A3A" CornerRadius="8" Padding="16,14"
                                        Width="260" Margin="0,0,12,8" BorderBrush="#1E1E3A" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1D4ED820" CornerRadius="4" Padding="4" Width="28" Height="28">
                                                <TextBlock Text="🔌" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="API 后端" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                                                <TextBlock Text="端口 5000" FontSize="10" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,6,0"
                                                             x:Name="ApiStatusDot"/>
                                                    <TextBlock x:Name="TxtApiStatus" Text="检查中..." FontSize="11" Foreground="#9CA3AF"/>
                                                </StackPanel>
                                                <TextBlock Text="http://localhost:5000" FontSize="10" Foreground="#4B5563"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="BtnApiStart" Content="▶ 启动" Style="{StaticResource ActionBtn}"
                                                    Width="62" Background="#059669" Click="BtnApiStart_Click"/>
                                            <Button x:Name="BtnApiStop" Content="⏹ 停止" Style="{StaticResource ActionBtn}"
                                                    Width="62" Margin="6,0,0,0" Background="#DC2626" Click="BtnApiStop_Click"/>
                                            <Button Content="🔄" Style="{StaticResource IconBtn}" Margin="6,0,0,0"
                                                    Click="BtnApiRestart_Click" ToolTip="重启"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Web 前端卡片 -->
                                <Border Background="#1A1A3A" CornerRadius="8" Padding="16,14"
                                        Width="260" Margin="0,0,12,8" BorderBrush="#1E1E3A" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#78350F20" CornerRadius="4" Padding="4" Width="28" Height="28">
                                                <TextBlock Text="🌐" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock Text="Web 前端" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                                                <TextBlock Text="端口 5173" FontSize="10" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,6,0"
                                                             x:Name="UiStatusDot"/>
                                                    <TextBlock x:Name="TxtUiStatus" Text="检查中..." FontSize="11" Foreground="#9CA3AF"/>
                                                </StackPanel>
                                                <TextBlock Text="http://localhost:5173" FontSize="10" Foreground="#4B5563"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="BtnUiStart" Content="▶ 启动" Style="{StaticResource ActionBtn}"
                                                    Width="62" Background="#059669" Click="BtnUiStart_Click"/>
                                            <Button x:Name="BtnUiStop" Content="⏹ 停止" Style="{StaticResource ActionBtn}"
                                                    Width="62" Margin="6,0,0,0" Background="#DC2626" Click="BtnUiStop_Click"/>
                                            <Button Content="🔄" Style="{StaticResource IconBtn}" Margin="6,0,0,0"
                                                    Click="BtnUiRestart_Click" ToolTip="重启"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ========== 2. 快捷入口 ========== -->
                    <Border Background="#14142A" CornerRadius="10" Padding="18,16" Margin="0,0,0,12"
                            BorderBrush="#1E1E3A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔗" FontSize="16"/>
                                <TextBlock Text="快捷入口" FontSize="15" FontWeight="Bold" Foreground="#E0E0E0" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🌐 本地画廊" Style="{StaticResource QuickLinkBtn}"
                                        Click="OpenLocalGallery_Click" ToolTip="打开本地画廊页面"/>
                                <Button Content="🔍 在线搜索" Style="{StaticResource QuickLinkBtn}" Margin="8,0,0,0"
                                        Click="OpenEhentai_Click" ToolTip="打开 E-Hentai 搜索页面" Background="#1A1A3A" Foreground="#A78BFA" BorderBrush="#407C3AED"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ========== 3. 下载任务 ========== -->
                    <Border Background="#14142A" CornerRadius="10" Padding="18,16" Margin="0,0,0,12"
                            BorderBrush="#1E1E3A" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="16"/>
                                    <TextBlock Text="下载任务" FontSize="15" FontWeight="Bold" Foreground="#E0E0E0" Margin="6,0,0,0"/>
                                    <TextBlock x:Name="TxtDownloadSummary" Text="" FontSize="12"
                                               Foreground="#6B7280" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="BtnRestartFailed" Content="🔄 重启全部失败" FontSize="11"
                                        Background="#78350F" Foreground="#FBBF24" BorderThickness="0"
                                        Padding="10,5" Cursor="Hand" HorizontalAlignment="Right"
                                        Click="BtnRestartFailed_Click" Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#78350F" CornerRadius="4" Padding="10,5"
                                                    BorderBrush="#40F59E0B" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="TasksList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1A3A" CornerRadius="8" Padding="14,12"
                                                    Margin="0,0,0,6" BorderBrush="#252545" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="#D1D5DB" MaxWidth="380" TextTrimming="CharacterEllipsis"/>
                                                            <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                                    Background="{Binding StatusBgBrush}">
                                                                <TextBlock Text="{Binding StatusText}" FontSize="10"
                                                                           Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <TextBlock FontSize="11" Foreground="#6B7280">
                                                                <Run Text="{Binding DownloadedPages}"/><Run Text=" / "/>
                                                                <Run Text="{Binding TotalPages}"/><Run Text=" 页"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding SpeedText}" FontSize="11"
                                                                       Foreground="#60A5FA" Margin="10,0,0,0" FontWeight="SemiBold"
                                                                       Visibility="{Binding SpeedVisible}"/>
                                                            <TextBlock Text="{Binding ErrorMsg}" FontSize="10"
                                                                       Foreground="#F87171" Margin="10,0,0,0" MaxWidth="200"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding ErrorVisible}"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,6,0,0">
                                                            <Border Height="5" CornerRadius="3" Background="#1E1E3A"/>
                                                            <Border Height="5" CornerRadius="3"
                                                                    Background="{Binding ProgressBrush}"
                                                                    HorizontalAlignment="Stretch"
                                                                    RenderTransformOrigin="0,0">
                                                                <Border.RenderTransform>
                                                                    <ScaleTransform ScaleX="{Binding ProgressFraction}"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                VerticalAlignment="Center" Margin="10,0,0,0">
                                                        <Button Content="⏸" FontSize="11" Background="#208B5CF6" Foreground="#A78BFA"
                                                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                                                Click="BtnPauseTask_Click" Tag="{Binding Gid}"
                                                                Visibility="{Binding PauseVisible}"/>
                                                        <Button Content="▶" FontSize="11" Background="#203B82F6" Foreground="#60A5FA"
                                                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                                                Click="BtnResumeTask_Click" Tag="{Binding Gid}" Margin="4,0,0,0"
                                                                Visibility="{Binding ResumeVisible}"/>
                                                        <Button Content="↻" FontSize="12" Background="#20F59E0B" Foreground="#FBBF24"
                                                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                                                Click="BtnRestartTask_Click" Tag="{Binding Gid}" Margin="4,0,0,0"
                                                                Visibility="{Binding RestartVisible}"/>
                                                        <Button Content="✕" FontSize="12" Background="#20EF4444" Foreground="#FCA5A5"
                                                                BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                                                Click="BtnRemoveTask_Click" Tag="{Binding Gid}" Margin="4,0,0,0"
                                                                Visibility="{Binding RemoveVisible}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="TxtNoTasks" Text="✨ 暂无下载任务" FontSize="12" Foreground="#4B5563"
                                       HorizontalAlignment="Center" Margin="0,16,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- ========== 4. 运行日志 ========== -->
                    <Border Background="#14142A" CornerRadius="10" Padding="18,16"
                            BorderBrush="#1E1E3A" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📋" FontSize="16"/>
                                <TextBlock Text="运行日志" FontSize="15" FontWeight="Bold" Foreground="#E0E0E0" Margin="6,0,0,0"/>
                                <Button Content="🗑 清空" FontSize="11" Background="#252545" Foreground="#6B7280"
                                        BorderThickness="0" Cursor="Hand" Margin="12,0,0,0" Padding="8,3"
                                        Click="ClearLog_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1" Background="#0A0A1A" CornerRadius="6"
                                    BorderBrush="#1E1E3A" BorderThickness="1">
                                <TextBox x:Name="TxtLog" Margin="10,8"
                                         Background="Transparent" Foreground="#9CA3AF" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11" IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                         MinHeight="110" MaxHeight="180"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
