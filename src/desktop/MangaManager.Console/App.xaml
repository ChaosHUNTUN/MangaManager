<Application x:Class="MangaManager.Console.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:MangaManager.Console">
    <Application.Resources>
        <ResourceDictionary>
            <local:ProgressToGridLengthConverter x:Key="ProgressConverter"/>

            <ContextMenu x:Key="TrayMenu" x:Shared="false">
                <MenuItem Header="📋 显示控制台" Click="ShowWindow_Click"/>
                <Separator/>
                <MenuItem Header="▶ 全部启动" Click="StartAll_Click"/>
                <MenuItem Header="⏹ 全部停止" Click="StopAll_Click"/>
                <Separator/>
                <MenuItem Header="🌐 打开网页" Click="OpenWeb_Click"/>
                <Separator/>
                <MenuItem Header="❌ 退出" Click="Exit_Click"/>
            </ContextMenu>

            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="/icon.ico"
                            ToolTipText="MangaManager"
                            ContextMenu="{StaticResource TrayMenu}"
                            x:Shared="false"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
