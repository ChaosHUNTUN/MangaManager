import re

# === Fix EhentaiService.cs: static methods using _logger ===
ehentai_path = "src/backend/MangaManager.Services/EhentaiService.cs"
content = open(ehentai_path, encoding="utf-8").read()
lines = content.split("\n")

# Find static method InitTagTranslationsAsync and replace _logger back to Console.WriteLine within it
in_static = False
brace = 0
new_lines = []
for line in lines:
    if "public static async Task InitTagTranslationsAsync" in line:
        in_static = True
    if in_static and "_logger.LogInformation" in line:
        line = line.replace("_logger.LogInformation", "Console.WriteLine")
    new_lines.append(line)
    if in_static:
        brace += line.count("{") - line.count("}")
        if brace == 0 and "{" in line:  # after the first { of the method
            pass
        elif brace == 0:
            in_static = False

open(ehentai_path, "w", encoding="utf-8").write("\n".join(new_lines))
print("Fixed EhentaiService.cs static methods")

