# === Fix MangaService.cs: needs ILogger injection ===
ms_path = "src/backend/MangaManager.Services/MangaService.cs"
content = open(ms_path, encoding="utf-8").read()

# Add using
if "using Microsoft.Extensions.Logging;" not in content:
    lines = content.split("\n")
    lines.insert(1, "using Microsoft.Extensions.Logging;")
    content = "\n".join(lines)

# Add _logger field
content = content.replace(
    "private readonly MangaDbContext _db;",
    "private readonly MangaDbContext _db;\n    private readonly ILogger<MangaService> _logger;"
)

# Update constructor
content = content.replace(
    "public MangaService(MangaDbContext db, IWebHostEnvironment env)",
    "public MangaService(MangaDbContext db, IWebHostEnvironment env, ILogger<MangaService> logger)"
)
content = content.replace(
    "        _db = db;\n        _env = env;",
    "        _logger = logger;\n        _db = db;\n        _env = env;"
)

# Replace Console.WriteLine -> _logger.LogInformation (should be none but just in case)
content = re.sub(r"Console\.WriteLine\(", "_logger.LogInformation(", content)
# Replace Debug.WriteLine -> _logger.LogDebug
content = re.sub(r"System\.Diagnostics\.Debug\.WriteLine\(", "_logger.LogDebug(", content)

open(ms_path, "w", encoding="utf-8").write(content)
print("Fixed MangaService.cs")

print("All fixes applied.")